{
  "name": "b3invest",
  "version": "1.0.0",
  "description": "Gerenciador de Carteira da Bolsa de Valores Brasileira",
  "main": "server/index.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install --legacy-peer-deps",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm install --legacy-peer-deps && npm run build",
    "postinstall": "cd client && npm install --legacy-peer-deps"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
