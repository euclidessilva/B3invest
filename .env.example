# =============================================================
# B3 Invest — Variáveis de Ambiente (Backend)
# =============================================================
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
# =============================================================

# ─── Supabase ───────────────────────────────────────
# Crie um projeto em https://supabase.com
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ─── brapi.dev (cotações B3) ────────────────────────
# Crie conta gratuita em https://brapi.dev
BRAPI_TOKEN=your_brapi_token

# Marque como "true" se você assinou um plano PAGO da brapi (PRO+).
# Habilita histórico real de dividendos (DY 12m exato + calendário oficial).
# Mantenha "false" no plano gratuito.
BRAPI_PRO=false

# ─── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Chave de convite (cadastro restrito) ───────────
# Defina aqui a chave que será exigida para novos cadastros
INVITE_KEY=sua_chave_de_convite

# ─── Administradores ────────────────────────────────
# E-mails (separados por vírgula) com acesso à área /admin
ADMIN_EMAILS=admin@exemplo.com

# ─── Client (variáveis expostas ao React) ───────────
# Estas devem ser duplicadas em client/.env
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SUPABASE_URL=https://xxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key
